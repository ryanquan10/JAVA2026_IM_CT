# ============================================================
# .dockerignore - Docker 构建时忽略的文件
# ============================================================

# Git
.git
.gitignore

# GitHub
.github

# Node modules
mg-page/node_modules
mg-page/package-lock.json
**/node_modules

# Maven 构建产物（由 Docker 自行构建）
bs-server/all/target
bs-server/*/target

# Docker (don't exclude docker/ itself - backend-jar and frontend-dist are build inputs)
docker/*.log
docker/tmp/

# 日志
logs/
*.log

# IDE
.idea
.vscode
*.iml

# OS
.DS_Store
Thumbs.db

# 临时文件
tmp/
temp/
*.tmp
