# ============================================================
# .env - CT_IM_JAVA 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================================

# ========== 外部数据库配置 ==========
DB_HOST=192.168.3.100
DB_PORT=3306
DB_NAME=tio_im
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ========== 应用环境 ==========
APP_ENV=production
JAVA_OPTS=-Xms512m -Xmx2046m
SERVER_PORT=8080

# ========== 部署配置 ==========
DEPLOY_HOST=localhost
DEPLOY_PORT=2222
DEPLOY_USER=debianuser
